{# Shared base layout for the live web UI (reports / live / camera-test /
   analytics). Children: {% extends "base.html.j2" %} and fill the title /
   style / content / script blocks. The active nav link is driven by the
   `active_page` variable ('reports' | 'live' | 'camera-test' | 'analytics').
   All CSS is inlined so the page stays Home Assistant ingress-safe (asset
   URLs honour X-Ingress-Path; nothing is served as a separate static file). #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light">
    <title>{% block title %}Camera Monitor{% endblock %}</title>
    <style>
        :root {
            /* Surfaces & text — clean & bright */
            --bg: #f6f8fc;
            --surface: #ffffff;
            --surface2: #f1f5f9;
            --border: #e7ebf2;
            --border-strong: #cbd5e1;
            --text: #0f172a;
            --text-muted: #475569;
            --text-faint: #94a3b8;

            /* Accent — brighter blue */
            --accent: #2563eb;
            --accent-hover: #1d4ed8;
            --accent-dim: rgba(37,99,235,0.10);
            --accent-grad: linear-gradient(135deg, #3b82f6, #2563eb);

            /* Status / semantic — soft pastel pills */
            --green: #16a34a;
            --green-dim: rgba(22,163,74,0.12);
            --amber: #d97706;
            --amber-dim: rgba(217,119,6,0.12);
            --red: #dc2626;
            --red-dim: rgba(220,38,38,0.10);
            --danger: #dc2626;
            --danger-hover: #b91c1c;
            --success-bg: rgba(22,163,74,0.12);
            --success-text: #15803d;
            --warn-bg: rgba(217,119,6,0.12);
            --warn-text: #b45309;
            --error-bg: rgba(220,38,38,0.10);
            --error-text: #b91c1c;
            --grey-bg: rgba(100,116,139,0.10);
            --grey-text: #475569;

            /* Shape & depth — rounder, soft indigo-tinted shadows */
            --radius: 16px;
            --radius-sm: 10px;
            --radius-xs: 8px;
            --shadow-sm: 0 1px 2px rgba(15,23,42,0.04), 0 1px 3px rgba(15,23,42,0.06);
            --shadow-md: 0 12px 32px rgba(37,99,235,0.12), 0 4px 12px rgba(15,23,42,0.06);
            --ring: 0 0 0 3px var(--accent-dim);

            /* Motion */
            --transition: 0.15s ease;

            --font-sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            --font-mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: var(--font-sans);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }
        h1 { font-size: 1.65rem; font-weight: 800; letter-spacing: -0.03em; }
        a { color: var(--accent); }
        :focus-visible { outline: none; box-shadow: var(--ring); border-radius: var(--radius-xs); }

        /* TOPBAR */
        .topbar {
            position: sticky; top: 0; z-index: 50;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(12px) saturate(1.4);
            -webkit-backdrop-filter: blur(12px) saturate(1.4);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 1px 12px rgba(15,23,42,0.05);
            padding: 0 1.75rem;
            display: flex; align-items: center; gap: 2rem;
            height: 64px;
        }
        .topbar-brand { font-size: 1rem; font-weight: 800; color: var(--text); display: flex; align-items: center; gap: 0.6rem; letter-spacing: -0.02em; white-space: nowrap; }
        .topbar-brand .brand-mark { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 10px; background: var(--accent-grad); color: #fff; box-shadow: 0 4px 12px rgba(37,99,235,0.35); }
        .topbar-nav { display: flex; gap: 0.3rem; align-items: center; overflow-x: auto; }
        .nav-link { display: flex; align-items: center; gap: 0.45rem; padding: 0.5rem 0.95rem; border-radius: 999px; font-size: 0.875rem; font-weight: 600; color: var(--text-muted); text-decoration: none; white-space: nowrap; transition: background var(--transition), color var(--transition), box-shadow var(--transition); }
        .nav-link:hover { background: var(--surface2); color: var(--text); }
        .nav-link.active { background: var(--accent-grad); color: #fff; box-shadow: 0 4px 14px rgba(37,99,235,0.30); }

        /* Hamburger toggle + mobile dropdown — hidden on desktop */
        .nav-toggle { display: none; margin-left: auto; align-items: center; justify-content: center; width: 42px; height: 42px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); color: var(--text); cursor: pointer; transition: background var(--transition), box-shadow var(--transition); }
        .nav-toggle:hover { background: var(--surface2); }
        .mobile-nav { display: none; }

        @media (max-width: 640px) {
            .topbar { gap: 1rem; padding: 0 1rem; }
            .topbar-nav { display: none; }
            .nav-toggle { display: flex; }
            .mobile-nav {
                display: block; position: fixed; top: 64px; left: 0; right: 0; z-index: 60;
                background: var(--surface); border-bottom: 1px solid var(--border);
                box-shadow: var(--shadow-md); padding: 0.5rem;
                border-radius: 0 0 var(--radius) var(--radius);
                max-height: 0; overflow: hidden; opacity: 0; visibility: hidden;
                transform: translateY(-8px); pointer-events: none;
                transition: max-height var(--transition), opacity var(--transition), transform var(--transition), visibility var(--transition);
            }
            .mobile-nav.open { max-height: 70vh; opacity: 1; visibility: visible; transform: translateY(0); pointer-events: auto; }
            .mobile-nav .nav-link { display: flex; min-height: 44px; border-radius: var(--radius-sm); padding: 0.65rem 0.95rem; font-size: 0.95rem; }
        }

        /* CONTENT */
        .content { max-width: {% block content_width %}900px{% endblock %}; margin: 0 auto; padding: 2.25rem 1.25rem; }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after { animation-duration: 0.001ms !important; animation-iteration-count: 1 !important; transition-duration: 0.001ms !important; }
        }
        {% block style %}{% endblock %}
    </style>
</head>
<body>
    {% set nav_items = [
        ('reports', ingress_path ~ '/', 'Reports', '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>'),
        ('live', ingress_path ~ '/live', 'Live', '<circle cx="12" cy="12" r="3"/><path d="M2 12C2 6.5 6.5 2 12 2s10 4.5 10 10-4.5 10-10 10S2 17.5 2 12z" opacity="0.3"/><path d="M2 12C2 6.5 6.5 2 12 2"/>'),
        ('camera-test', ingress_path ~ '/camera-test', 'Camera Test', '<path d="M20 17v2H2v-2"/><rect x="3" y="5" width="18" height="12" rx="2"/>'),
        ('analytics', ingress_path ~ '/analytics', 'Analytics', '<polyline points="23 6 13.5 15.5 8.5 10.5 1 17"/><polyline points="17 6 23 6 23 12"/>'),
    ] %}
    <nav class="topbar">
        <div class="topbar-brand">
            <span class="brand-mark"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg></span>
            Camera Monitor
        </div>
        <div class="topbar-nav">
            {% for key, href, label, icon in nav_items %}
            <a class="nav-link{% if active_page == key %} active{% endif %}" href="{{ href }}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">{{ icon | safe }}</svg>
                {{ label }}
            </a>
            {% endfor %}
        </div>
        <button class="nav-toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="mobile-nav">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
    </nav>
    <div class="mobile-nav" id="mobile-nav">
        {% for key, href, label, icon in nav_items %}
        <a class="nav-link{% if active_page == key %} active{% endif %}" href="{{ href }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">{{ icon | safe }}</svg>
            {{ label }}
        </a>
        {% endfor %}
    </div>

    <div class="content">
        {% block content %}{% endblock %}
    </div>

    {% block body_end %}{% endblock %}
    <script>
        (function () {
            var btn = document.querySelector('.nav-toggle');
            var menu = document.getElementById('mobile-nav');
            if (!btn || !menu) return;
            function close() { menu.classList.remove('open'); btn.setAttribute('aria-expanded', 'false'); }
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                var open = menu.classList.toggle('open');
                btn.setAttribute('aria-expanded', open ? 'true' : 'false');
            });
            menu.addEventListener('click', function (e) { if (e.target.closest('a')) close(); });
            document.addEventListener('click', function (e) {
                if (!menu.contains(e.target) && !btn.contains(e.target)) close();
            });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
        })();
    </script>
    {% block script %}{% endblock %}
</body>
</html>
