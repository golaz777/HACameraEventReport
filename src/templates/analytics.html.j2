<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics</title>
    <style>
        :root {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface2: #273244;
            --border: #334155;
            --text: #f1f5f9;
            --text-muted: #94a3b8;
            --accent: #3b82f6;
            --accent-hover: #2563eb;
            --accent-dim: rgba(59,130,246,0.15);
            --green: #22c55e;
            --green-dim: rgba(34,197,94,0.15);
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

        /* NAV */
        .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 1.5rem; display: flex; align-items: center; gap: 1.5rem; height: 52px; }
        .topbar-brand { font-size: 0.95rem; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 0.5rem; letter-spacing: -0.01em; white-space: nowrap; }
        .topbar-brand svg { opacity: 0.8; }
        .topbar-nav { display: flex; gap: 0.25rem; align-items: center; }
        .nav-link { display: flex; align-items: center; gap: 0.4rem; padding: 0.35rem 0.85rem; border-radius: 6px; font-size: 0.875rem; font-weight: 500; color: var(--text-muted); text-decoration: none; transition: background 0.15s, color 0.15s; }
        .nav-link:hover { background: var(--surface2); color: var(--text); }
        .nav-link.active { background: var(--accent-dim); color: var(--accent); }

        /* CONTENT */
        .content { max-width: 960px; margin: 0 auto; padding: 1.75rem 1rem; }
        .page-header { margin-bottom: 2rem; }
        h1 { font-size: 1.35rem; font-weight: 700; margin-bottom: 0.5rem; }
        .header-subtitle { font-size: 0.875rem; color: var(--text-muted); }

        /* STATS GRID */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
        .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; }
        .stat-label { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 0.5rem; }
        .stat-value { font-size: 2rem; font-weight: 700; color: var(--accent); }
        .stat-detail { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.35rem; }

        /* CHART SECTIONS */
        .chart-section { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem; }
        .chart-title { font-size: 1.05rem; font-weight: 600; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }

        /* BAR CHART */
        .bar-chart { display: flex; flex-direction: column; gap: 0.5rem; }
        .bar-row { display: flex; align-items: center; gap: 0.75rem; }
        .bar-label { min-width: 80px; font-size: 0.875rem; color: var(--text-muted); text-align: right; }
        .bar-container { flex: 1; height: 24px; background: var(--surface2); border-radius: 4px; position: relative; min-width: 0; }
        .bar { height: 100%; background: var(--accent); border-radius: 4px; width: var(--pct); transition: width 0.3s ease; }
        .bar-value { min-width: 30px; font-size: 0.875rem; color: var(--text); text-align: left; }

        /* HOUR HEATMAP */
        .hour-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(35px, 1fr)); gap: 0.3rem; }
        .hour-cell { aspect-ratio: 1; background: var(--surface2); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 500; color: var(--text-muted); position: relative; }
        .hour-cell-filled { background: var(--accent); color: #fff; }
        .hour-label { font-size: 0.7rem; text-align: center; color: var(--text-muted); margin-top: 0.25rem; }

        /* EMPTY STATE */
        .empty-message { text-align: center; color: var(--text-muted); padding: 2rem; }
    </style>
</head>
<body>
    <nav class="topbar">
        <div class="topbar-brand">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
            Camera Monitor
        </div>
        <div class="topbar-nav">
            <a class="nav-link" href="{{ ingress_path }}/">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Reports
            </a>
            <a class="nav-link" href="{{ ingress_path }}/live">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M2 12C2 6.5 6.5 2 12 2s10 4.5 10 10-4.5 10-10 10S2 17.5 2 12z" opacity="0.3"/><path d="M2 12C2 6.5 6.5 2 12 2"/></svg>
                Live
            </a>
            <a class="nav-link" href="{{ ingress_path }}/camera-test">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 17v2H2v-2"/><rect x="3" y="5" width="18" height="12" rx="2"/></svg>
                Camera Test
            </a>
            <a class="nav-link active" href="{{ ingress_path }}/analytics">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 17"/><polyline points="17 6 23 6 23 12"/></svg>
                Analytics
            </a>
        </div>
    </nav>

    <div class="content">
        <div class="page-header">
            <h1>Motion Analytics</h1>
            <p class="header-subtitle">Last {{ days }} day{{ 's' if days != 1 else '' }}</p>
        </div>

        {% if total_events == 0 %}
        <div class="empty-message">
            <p>No motion events detected in the selected period.</p>
        </div>
        {% else %}

        <!-- STATS GRID -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Total Events</div>
                <div class="stat-value">{{ total_events }}</div>
            </div>
            {% if peak_day %}
            <div class="stat-card">
                <div class="stat-label">Peak Day</div>
                <div class="stat-value">{{ peak_count }}</div>
                <div class="stat-detail">{{ peak_day }}</div>
            </div>
            {% endif %}
            {% if busiest_camera %}
            <div class="stat-card">
                <div class="stat-label">Busiest Camera</div>
                <div class="stat-value">{{ busiest_count }}</div>
                <div class="stat-detail">{{ busiest_camera }}</div>
            </div>
            {% endif %}
        </div>

        <!-- EVENTS PER DAY -->
        <div class="chart-section">
            <div class="chart-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="12 3 20 7.5 20 16.5 12 21 4 16.5 4 7.5 12 3"/><polyline points="12 12 20 7.5"/><polyline points="12 21 12 12"/><polyline points="4 7.5 12 12"/></svg>
                Events Per Day
            </div>
            <div class="bar-chart">
                {% for date, count in per_day %}
                <div class="bar-row">
                    <div class="bar-label">{{ date }}</div>
                    <div class="bar-container">
                        <div class="bar" style="--pct: {{ (count / max_per_day * 100) | int }}%"></div>
                    </div>
                    <div class="bar-value">{{ count }}</div>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- EVENTS PER CAMERA -->
        {% if per_camera %}
        <div class="chart-section">
            <div class="chart-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                Events Per Camera
            </div>
            <div class="bar-chart">
                {% for camera, count in per_camera %}
                <div class="bar-row">
                    <div class="bar-label">{{ camera }}</div>
                    <div class="bar-container">
                        <div class="bar" style="--pct: {{ (count / max_per_camera * 100) | int }}%"></div>
                    </div>
                    <div class="bar-value">{{ count }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- EVENTS BY HOUR -->
        <div class="chart-section">
            <div class="chart-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 6 12 12 16 14"/></svg>
                Events By Hour of Day
            </div>
            <div class="hour-grid">
                {% for hour, count in by_hour %}
                <div>
                    <div class="hour-cell {% if count > 0 %}hour-cell-filled{% endif %}" style="{% if count > 0 %}--pct: {{ (count / max_by_hour * 100) | int }}%{% endif %}" title="{{ count }} events at {{ '%02d'|format(hour) }}:00">
                        {% if count > 0 %}{{ count }}{% else %}&nbsp;{% endif %}
                    </div>
                    <div class="hour-label">{{ '%02d'|format(hour) }}</div>
                </div>
                {% endfor %}
            </div>
        </div>

        {% endif %}
    </div>
</body>
</html>
