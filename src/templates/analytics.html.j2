{% extends "base.html.j2" %}
{% block title %}Analytics{% endblock %}
{% block content_width %}960px{% endblock %}

{% block style %}
        .page-header { margin-bottom: 2rem; }
        h1 { margin-bottom: 0.5rem; }
        .header-subtitle { font-size: 0.875rem; color: var(--text-muted); }

        /* STATS GRID */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
        .stat-card { position: relative; overflow: hidden; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.4rem 1.5rem; box-shadow: var(--shadow-sm); transition: transform var(--transition), box-shadow var(--transition); }
        .stat-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--accent-grad); }
        .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
        .stat-label { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.5rem; }
        .stat-value { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1.05; background: var(--accent-grad); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
        .stat-detail { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.35rem; }

        /* CHART SECTIONS */
        .chart-section { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; margin-bottom: 1.5rem; box-shadow: var(--shadow-sm); }
        .chart-title { font-size: 1.05rem; font-weight: 600; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
        .chart-title svg { color: var(--accent); }

        /* BAR CHART */
        .bar-chart { display: flex; flex-direction: column; gap: 0.5rem; }
        .bar-row { display: flex; align-items: center; gap: 0.75rem; }
        .bar-label { min-width: 80px; font-size: 0.875rem; color: var(--text-muted); text-align: right; }
        .bar-container { flex: 1; height: 24px; background: var(--surface2); border-radius: var(--radius-xs); position: relative; min-width: 0; }
        .bar { height: 100%; background: var(--accent-grad); border-radius: var(--radius-xs); width: var(--pct); transition: width 0.4s ease; }
        .bar-value { min-width: 30px; font-size: 0.875rem; color: var(--text); text-align: left; font-variant-numeric: tabular-nums; }

        /* HOUR HEATMAP */
        .hour-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(35px, 1fr)); gap: 0.3rem; }
        .hour-cell { aspect-ratio: 1; background: var(--surface2); border-radius: var(--radius-xs); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 600; color: var(--text-muted); position: relative; overflow: hidden; }
        .hour-cell-filled { color: #fff; }
        .hour-cell-filled::before { content: ""; position: absolute; inset: 0; background: var(--accent); opacity: calc(0.25 + 0.75 * var(--intensity)); }
        .hour-cell span { position: relative; }
        .hour-label { font-size: 0.7rem; text-align: center; color: var(--text-muted); margin-top: 0.25rem; }

        /* EMPTY STATE */
        .empty-message { text-align: center; color: var(--text-muted); padding: 2rem; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
        .empty-message svg { color: var(--text-faint); }
{% endblock %}

{% block content %}
        <div class="page-header">
            <h1>Motion Analytics</h1>
            <p class="header-subtitle">Last {{ days }} day{{ 's' if days != 1 else '' }}</p>
        </div>

        {% if total_events == 0 %}
        <div class="empty-message">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 17"/><polyline points="17 6 23 6 23 12"/></svg>
            <p>No motion events detected in the selected period.</p>
        </div>
        {% else %}

        <!-- STATS GRID -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Total Events</div>
                <div class="stat-value">{{ total_events }}</div>
            </div>
            {% if peak_day %}
            <div class="stat-card">
                <div class="stat-label">Peak Day</div>
                <div class="stat-value">{{ peak_count }}</div>
                <div class="stat-detail">{{ peak_day }}</div>
            </div>
            {% endif %}
            {% if busiest_camera %}
            <div class="stat-card">
                <div class="stat-label">Busiest Camera</div>
                <div class="stat-value">{{ busiest_count }}</div>
                <div class="stat-detail">{{ busiest_camera }}</div>
            </div>
            {% endif %}
        </div>

        <!-- EVENTS PER DAY -->
        <div class="chart-section">
            <div class="chart-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="12 3 20 7.5 20 16.5 12 21 4 16.5 4 7.5 12 3"/><polyline points="12 12 20 7.5"/><polyline points="12 21 12 12"/><polyline points="4 7.5 12 12"/></svg>
                Events Per Day
            </div>
            <div class="bar-chart">
                {% for date, count in per_day %}
                <div class="bar-row">
                    <div class="bar-label">{{ date }}</div>
                    <div class="bar-container">
                        <div class="bar" style="--pct: {{ (count / max_per_day * 100) | int }}%"></div>
                    </div>
                    <div class="bar-value">{{ count }}</div>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- EVENTS PER CAMERA -->
        {% if per_camera %}
        <div class="chart-section">
            <div class="chart-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                Events Per Camera
            </div>
            <div class="bar-chart">
                {% for camera, count in per_camera %}
                <div class="bar-row">
                    <div class="bar-label">{{ camera }}</div>
                    <div class="bar-container">
                        <div class="bar" style="--pct: {{ (count / max_per_camera * 100) | int }}%"></div>
                    </div>
                    <div class="bar-value">{{ count }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- EVENTS BY HOUR -->
        <div class="chart-section">
            <div class="chart-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 6 12 12 16 14"/></svg>
                Events By Hour of Day
            </div>
            <div class="hour-grid">
                {% for hour, count in by_hour %}
                <div>
                    <div class="hour-cell {% if count > 0 %}hour-cell-filled{% endif %}" style="{% if count > 0 %}--intensity: {{ '%.3f'|format(count / max_by_hour) }}{% endif %}" title="{{ count }} events at {{ '%02d'|format(hour) }}:00">
                        <span>{% if count > 0 %}{{ count }}{% else %}&nbsp;{% endif %}</span>
                    </div>
                    <div class="hour-label">{{ '%02d'|format(hour) }}</div>
                </div>
                {% endfor %}
            </div>
        </div>

        {% endif %}
{% endblock %}
