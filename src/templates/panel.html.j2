{% extends "base.html.j2" %}
{% block title %}Camera Test{% endblock %}

{% block style %}
        h1 { margin-bottom: 1.5rem; }
        .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem 1.25rem; margin-bottom: 0.75rem; box-shadow: var(--shadow-sm); transition: transform var(--transition), box-shadow var(--transition); }
        .card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
        .camera-name { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; }
        .test-btn { padding: 0.4rem 1rem; font-size: 0.875rem; font-weight: 500; background: var(--accent-grad); color: #fff; border: none; border-radius: var(--radius-xs); cursor: pointer; box-shadow: var(--shadow-sm); transition: filter var(--transition); }
        .test-btn:hover { filter: brightness(1.1); }
        .test-btn:disabled { opacity: 0.45; cursor: not-allowed; }
        .result { margin-top: 0.75rem; }
        .badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: var(--radius-xs); font-size: 0.82rem; font-weight: 500; }
        .badge-green { background: var(--success-bg); color: var(--success-text); }
        .badge-amber { background: var(--warn-bg); color: var(--warn-text); }
        .badge-grey  { background: var(--grey-bg); color: var(--grey-text); }
        .error-banner { background: var(--error-bg); color: var(--error-text); padding: 0.45rem 0.75rem; border-radius: var(--radius-xs); margin-bottom: 0.5rem; font-size: 0.875rem; }
        .snapshot { margin-top: 0.75rem; max-width: 100%; border-radius: var(--radius-sm); display: block; border: 1px solid var(--border); }
        .empty { color: var(--text-muted); text-align: center; padding: 3rem 0; }
{% endblock %}

{% block content %}
        <h1>Camera Test</h1>
        {% for camera in cameras %}
        <div class="card">
            <div class="camera-name">{{ camera.name }}</div>
            <button class="test-btn" id="btn-{{ camera.slug }}" onclick="runTest('{{ camera.slug }}')">Test snapshot</button>
            <div class="result" id="result-{{ camera.slug }}"></div>
        </div>
        {% else %}
        <p class="empty">No cameras configured.</p>
        {% endfor %}
{% endblock %}

{% block script %}
    <script>
    const INGRESS_PATH = {{ ingress_path | tojson }};
    async function runTest(slug) {
        const btn = document.getElementById('btn-' + slug);
        const resultDiv = document.getElementById('result-' + slug);
        btn.disabled = true;
        resultDiv.innerHTML = '<span class="badge badge-grey">Testing…</span>';
        try {
            const resp = await fetch(INGRESS_PATH + '/test/' + slug, { method: 'POST' });
            const data = await resp.json();
            let html = '';
            if (!data.ok) {
                html += '<div class="error-banner">Snapshot unavailable</div>';
            } else {
                html += '<span class="badge badge-green">Snapshot ✓</span>';
            }
            if (data.snapshot_b64) {
                html += '<img class="snapshot" src="data:image/jpeg;base64,' + data.snapshot_b64 + '" alt="Camera snapshot">';
            } else {
                html += '<br><span class="badge badge-amber" style="margin-top:0.5rem;display:inline-block;">No snapshot</span>';
            }
            resultDiv.innerHTML = html;
        } catch (e) {
            resultDiv.innerHTML = '<div class="error-banner">Request failed: ' + e.message + '</div>';
        } finally {
            btn.disabled = false;
        }
    }
    </script>
{% endblock %}
