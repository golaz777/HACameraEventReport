{# Shared fullscreen snapshot lightbox: styles, markup, and the initLightbox()
   controller. Host pages call initLightbox({src, caption, prev, next, detached?}),
   where each callback receives the current DOM node, and use the returned
   { open, close, nav } API. Relies on --surface / --border / --text CSS vars
   defined by the host page. See report.html.j2 and live.html.j2. #}
<style>
  .lightbox { position: fixed; inset: 0; z-index: 1000; background: rgba(0,0,0,0.9); display: flex; align-items: center; justify-content: center; padding: 2rem; }
  #lb-img { max-width: 90vw; max-height: 85vh; object-fit: contain; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.5); border: none; cursor: zoom-out; }
  .lb-caption { position: fixed; bottom: 1.25rem; left: 50%; transform: translateX(-50%); font-size: 0.85rem; color: var(--text); background: rgba(31,41,55,0.9); border: 1px solid var(--border); border-radius: 99px; padding: 0.3rem 0.9rem; font-variant-numeric: tabular-nums; }
  .lb-btn { position: fixed; display: flex; align-items: center; justify-content: center; background: var(--surface); color: var(--text); border: 1px solid var(--border); border-radius: 50%; cursor: pointer; line-height: 1; transition: background 0.15s, opacity 0.15s; }
  .lb-btn:hover:not(:disabled) { background: var(--border); }
  .lb-btn:disabled { opacity: 0.25; cursor: default; }
  .lb-close { top: 1rem; right: 1.25rem; width: 2.4rem; height: 2.4rem; font-size: 1.5rem; }
  .lb-nav { top: 50%; transform: translateY(-50%); width: 3rem; height: 3rem; font-size: 1.75rem; }
  .lb-prev { left: 1.25rem; }
  .lb-next { right: 1.25rem; }
</style>

<div id="lightbox" class="lightbox" style="display:none">
  <button class="lb-btn lb-close" id="lb-close" aria-label="Close">&times;</button>
  <button class="lb-btn lb-nav lb-prev" id="lb-prev" aria-label="Previous">&#8249;</button>
  <img id="lb-img" src="" alt="full size snapshot">
  <div class="lb-caption" id="lb-caption"></div>
  <button class="lb-btn lb-nav lb-next" id="lb-next" aria-label="Next">&#8250;</button>
</div>

<script>
  function initLightbox(opts) {
    var box = document.getElementById('lightbox');
    var img = document.getElementById('lb-img');
    var cap = document.getElementById('lb-caption');
    var btnPrev = document.getElementById('lb-prev');
    var btnNext = document.getElementById('lb-next');
    var cur = null;

    function render() {
      img.src = opts.src(cur);
      cap.textContent = opts.caption(cur) || '';
      btnPrev.disabled = !opts.prev(cur);
      btnNext.disabled = !opts.next(cur);
    }
    function open(node) { cur = node; render(); box.style.display = 'flex'; }
    function close() { box.style.display = 'none'; cur = null; }
    function nav(dir) {
      if (!cur) return;
      var n = dir < 0 ? opts.prev(cur) : opts.next(cur);
      if (n) { cur = n; render(); }
    }

    btnPrev.addEventListener('click', function (e) { e.stopPropagation(); nav(-1); });
    btnNext.addEventListener('click', function (e) { e.stopPropagation(); nav(1); });
    document.getElementById('lb-close').addEventListener('click', close);
    img.addEventListener('click', close);
    box.addEventListener('click', function (e) { if (e.target === box) close(); });

    document.addEventListener('keydown', function (e) {
      if (box.style.display === 'none') return;
      // Bail out if the open node was removed from the DOM (e.g. trimmed feed).
      if (cur && opts.detached && opts.detached(cur)) { close(); return; }
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); nav(-1); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); nav(1); }
    });

    return { open: open, close: close, nav: nav };
  }
</script>
