<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Events</title>
    <style>
        :root {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface2: #273244;
            --border: #334155;
            --text: #f1f5f9;
            --text-muted: #94a3b8;
            --accent: #3b82f6;
            --accent-hover: #2563eb;
            --accent-dim: rgba(59,130,246,0.15);
            --green: #22c55e;
            --green-dim: rgba(34,197,94,0.15);
            --amber: #f59e0b;
            --amber-dim: rgba(245,158,11,0.15);
            --red: #ef4444;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

        /* NAV */
        .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 1.5rem; display: flex; align-items: center; gap: 1.5rem; height: 52px; }
        .topbar-brand { font-size: 0.95rem; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 0.5rem; letter-spacing: -0.01em; white-space: nowrap; }
        .topbar-brand svg { opacity: 0.8; }
        .topbar-nav { display: flex; gap: 0.25rem; align-items: center; }
        .nav-link { display: flex; align-items: center; gap: 0.4rem; padding: 0.35rem 0.85rem; border-radius: 6px; font-size: 0.875rem; font-weight: 500; color: var(--text-muted); text-decoration: none; transition: background 0.15s, color 0.15s; }
        .nav-link:hover { background: var(--surface2); color: var(--text); }
        .nav-link.active { background: var(--accent-dim); color: var(--accent); }

        /* CONTENT */
        .content { max-width: 860px; margin: 0 auto; padding: 1.75rem 1rem; }
        .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; gap: 1rem; flex-wrap: wrap; }
        h1 { font-size: 1.35rem; font-weight: 700; }

        /* STATUS PILL */
        .status-pill { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; font-weight: 600; border-radius: 99px; padding: 0.2rem 0.7rem; }
        .status-pill .dot { width: 7px; height: 7px; border-radius: 50%; }
        .status-connecting { background: var(--amber-dim); color: var(--amber); }
        .status-connecting .dot { background: var(--amber); animation: pulse 1.2s ease-in-out infinite; }
        .status-connected { background: var(--green-dim); color: var(--green); }
        .status-connected .dot { background: var(--green); }
        .status-error { background: rgba(239,68,68,0.15); color: var(--red); }
        .status-error .dot { background: var(--red); }
        @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

        /* EVENT FEED */
        .feed-empty { color: var(--text-muted); text-align: center; padding: 4rem 0; font-size: 0.9rem; }
        .feed { display: flex; flex-direction: column; gap: 0.75rem; }

        .event-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            display: flex;
            gap: 0;
            animation: slideIn 0.25s ease;
        }
        @keyframes slideIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: none; } }

        .event-thumb {
            width: 120px;
            min-width: 120px;
            background: var(--surface2);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .event-thumb img { width: 120px; height: 90px; object-fit: cover; display: block; }
        .event-thumb-placeholder {
            width: 120px;
            height: 90px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--border);
        }

        .event-body { padding: 0.75rem 1rem; flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.25rem; justify-content: center; }
        .event-camera { font-size: 0.975rem; font-weight: 600; color: var(--text); }
        .event-time { font-size: 0.8rem; color: var(--text-muted); font-variant-numeric: tabular-nums; }
        .event-entity { font-size: 0.75rem; color: var(--border); font-family: ui-monospace, monospace; margin-top: 0.1rem; }

        .count-badge { font-size: 0.78rem; color: var(--text-muted); background: var(--surface); border: 1px solid var(--border); border-radius: 99px; padding: 0.15rem 0.65rem; }
    </style>
</head>
<body>
    <nav class="topbar">
        <div class="topbar-brand">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
            Camera Monitor
        </div>
        <div class="topbar-nav">
            <a class="nav-link" href="{{ ingress_path }}/">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Reports
            </a>
            <a class="nav-link active" href="{{ ingress_path }}/live">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M2 12C2 6.5 6.5 2 12 2s10 4.5 10 10-4.5 10-10 10S2 17.5 2 12z" opacity="0.3"/><path d="M2 12C2 6.5 6.5 2 12 2"/></svg>
                Live
            </a>
            <a class="nav-link" href="{{ ingress_path }}/camera-test">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 17v2H2v-2"/><rect x="3" y="5" width="18" height="12" rx="2"/></svg>
                Camera Test
            </a>
            <a class="nav-link" href="{{ ingress_path }}/analytics">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 17"/><polyline points="17 6 23 6 23 12"/></svg>
                Analytics
            </a>
        </div>
    </nav>

    <div class="content">
        <div class="page-header">
            <h1>Live Events</h1>
            <div style="display:flex;align-items:center;gap:0.75rem;">
                <span class="count-badge" id="count-badge" style="display:none"></span>
                <span class="status-pill status-connecting" id="status-pill">
                    <span class="dot"></span>
                    <span id="status-text">Connecting</span>
                </span>
            </div>
        </div>

        <div id="feed-empty" class="feed-empty">Waiting for motion events&hellip;</div>
        <div id="feed" class="feed" style="display:none"></div>
    </div>

    <script>
    const INGRESS_PATH = {{ ingress_path | tojson }};
    const MAX_EVENTS = 50;
    let eventCount = 0;
    let es = null;
    let reconnectDelay = 1000;

    const pill = document.getElementById('status-pill');
    const statusText = document.getElementById('status-text');
    const feed = document.getElementById('feed');
    const feedEmpty = document.getElementById('feed-empty');
    const countBadge = document.getElementById('count-badge');

    function setStatus(state) {
        pill.className = 'status-pill status-' + state;
        statusText.textContent = state.charAt(0).toUpperCase() + state.slice(1);
    }

    function formatTime(isoStr) {
        try {
            const d = new Date(isoStr);
            return d.toLocaleString(undefined, {
                month: 'short', day: 'numeric',
                hour: '2-digit', minute: '2-digit', second: '2-digit',
                hour12: false
            });
        } catch { return isoStr; }
    }

    function addEvent(data) {
        eventCount++;
        countBadge.textContent = eventCount + ' event' + (eventCount !== 1 ? 's' : '');
        countBadge.style.display = '';
        feedEmpty.style.display = 'none';
        feed.style.display = '';

        const card = document.createElement('div');
        card.className = 'event-card';

        let thumbHtml;
        if (data.screenshot_b64) {
            thumbHtml = `<div class="event-thumb"><img src="data:image/jpeg;base64,${data.screenshot_b64}" alt="snapshot" loading="lazy"></div>`;
        } else {
            thumbHtml = `<div class="event-thumb"><div class="event-thumb-placeholder"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg></div></div>`;
        }

        card.innerHTML = thumbHtml + `
            <div class="event-body">
                <div class="event-camera">${escHtml(data.camera_name)}</div>
                <div class="event-time">${formatTime(data.timestamp)}</div>
                <div class="event-entity">${escHtml(data.camera_entity)}</div>
            </div>`;

        feed.insertBefore(card, feed.firstChild);

        // Trim to MAX_EVENTS
        while (feed.children.length > MAX_EVENTS) {
            feed.removeChild(feed.lastChild);
        }
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function connect() {
        setStatus('connecting');
        es = new EventSource(INGRESS_PATH + '/events/stream');

        es.onopen = () => {
            setStatus('connected');
            reconnectDelay = 1000;
        };

        es.onmessage = (e) => {
            try {
                const data = JSON.parse(e.data);
                addEvent(data);
            } catch {}
        };

        es.onerror = () => {
            setStatus('error');
            es.close();
            setTimeout(connect, reconnectDelay);
            reconnectDelay = Math.min(reconnectDelay * 2, 30000);
        };
    }

    connect();
    </script>
</body>
</html>
