<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Motion Report – {{ night }}</title>
  <style>
    :root {
      --bg: #111827;
      --surface: #1f2937;
      --border: #374151;
      --text: #f3f4f6;
      --text-muted: #9ca3af;
      --accent: #3b82f6;
      --th-bg: #1a2540;
      --row-alt: #18222f;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: sans-serif; background: var(--bg); color: var(--text); max-width: 980px; margin: 0 auto; padding: 1.5rem 1rem; }
    h1 { font-size: 1.4rem; font-weight: 600; margin-bottom: 1.25rem; }
    .summary { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.8; }
    .summary strong { color: var(--text-muted); font-weight: 500; }
    .summary span { color: var(--text); font-weight: 600; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 2rem; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
    th { background: var(--th-bg); color: var(--text-muted); font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.6rem 1rem; text-align: left; }
    td { padding: 0.5rem 1rem; border-bottom: 1px solid var(--border); vertical-align: middle; font-size: 0.9rem; }
    tr:last-child td { border-bottom: none; }
    tr:nth-child(even) td { background: var(--row-alt); }
    img { max-width: 240px; max-height: 180px; border-radius: 4px; display: block; cursor: zoom-in; border: 1px solid var(--border); }
    .img-link:hover img { opacity: 0.8; }
    #lightbox { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 1000; align-items: center; justify-content: center; }
    #lightbox.open { display: flex; }
    #lightbox img { max-width: 92vw; max-height: 85vh; border-radius: 6px; box-shadow: 0 4px 32px #000; border: none; cursor: zoom-out; }
    .lb-caption { position: fixed; bottom: 1.25rem; left: 50%; transform: translateX(-50%); font-size: 0.85rem; color: var(--text); background: rgba(31,41,55,0.9); border: 1px solid var(--border); border-radius: 99px; padding: 0.3rem 0.9rem; font-variant-numeric: tabular-nums; }
    .lb-btn { position: fixed; display: flex; align-items: center; justify-content: center; background: var(--surface); color: var(--text); border: 1px solid var(--border); border-radius: 50%; cursor: pointer; line-height: 1; transition: background 0.15s, opacity 0.15s; }
    .lb-btn:hover:not(:disabled) { background: var(--border); }
    .lb-btn:disabled { opacity: 0.25; cursor: default; }
    .lb-close { top: 1rem; right: 1.25rem; width: 2.4rem; height: 2.4rem; font-size: 1.5rem; }
    .lb-nav { top: 50%; transform: translateY(-50%); width: 3rem; height: 3rem; font-size: 1.75rem; }
    .lb-prev { left: 1.25rem; }
    .lb-next { right: 1.25rem; }
    .no-snap { color: var(--text-muted); font-style: italic; font-size: 0.85rem; }
    .no-events { color: var(--text-muted); font-style: italic; padding: 2rem 0; }
  </style>
</head>
<body>
  <h1>Motion Report</h1>
  <div class="summary">
    <strong>Date:</strong> <span>{{ night }}</span><br>
    <strong>Window:</strong> <span>{{ sunset_time }} → {{ sunrise_time }}</span><br>
    <strong>Total events:</strong> <span>{{ events|length }}</span>
  </div>

  {% if events %}
  <table>
    <thead>
      <tr><th>Time (CET)</th><th>Camera</th><th>Screenshot</th></tr>
    </thead>
    <tbody>
      {% for event in events %}
      <tr>
        <td>{{ event.timestamp.strftime("%H:%M:%S") }}</td>
        <td>{{ event.camera_name }}</td>
        <td>
          {% if event.screenshot_b64 %}
          <a class="img-link" href="#" data-caption="{{ event.timestamp.strftime('%H:%M:%S') }} · {{ event.camera_name }}" onclick="openLightbox(this);return false;">
            <img src="data:image/jpeg;base64,{{ event.screenshot_b64 }}" alt="snapshot {{ event.camera_name }}">
          </a>
          {% else %}
          <span class="no-snap">snapshot unavailable</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="no-events">No motion events detected during this session.</p>
  {% endif %}

  <div id="lightbox">
    <button class="lb-btn lb-close" onclick="closeLightbox()" aria-label="Close">&times;</button>
    <button class="lb-btn lb-nav lb-prev" id="lb-prev" onclick="navReport(-1)" aria-label="Previous">&#8249;</button>
    <img id="lightbox-img" src="" alt="full size snapshot" onclick="closeLightbox()">
    <button class="lb-btn lb-nav lb-next" id="lb-next" onclick="navReport(1)" aria-label="Next">&#8250;</button>
    <div class="lb-caption" id="lb-caption"></div>
  </div>
  <script>
    var lbLinks = [];
    var lbIndex = -1;
    var lightbox = document.getElementById('lightbox');

    function renderLb() {
      var link = lbLinks[lbIndex];
      document.getElementById('lightbox-img').src = link.querySelector('img').src;
      document.getElementById('lb-caption').textContent = link.getAttribute('data-caption') || '';
      document.getElementById('lb-prev').disabled = lbIndex <= 0;
      document.getElementById('lb-next').disabled = lbIndex >= lbLinks.length - 1;
    }

    function openLightbox(link) {
      lbLinks = Array.prototype.slice.call(document.querySelectorAll('.img-link'));
      lbIndex = lbLinks.indexOf(link);
      renderLb();
      lightbox.classList.add('open');
    }

    function navReport(dir) {
      var n = lbIndex + dir;
      if (n < 0 || n >= lbLinks.length) return;
      lbIndex = n;
      renderLb();
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
    }

    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', function(e) {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape') closeLightbox();
      else if (e.key === 'ArrowLeft') { e.preventDefault(); navReport(-1); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); navReport(1); }
    });
  </script>
</body>
</html>
