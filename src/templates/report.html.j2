<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light">
  <title>Motion Report – {{ night }}</title>
  <style>
    /* Standalone saved report — palette aligned to the live app (clean & bright).
       This file is written to disk and viewed on its own, so its theme tokens
       are self-contained (the shared _lightbox include relies on
       --surface / --border / --text being defined here). */
    :root {
      --bg: #f6f8fc;
      --surface: #ffffff;
      --surface2: #f1f5f9;
      --border: #e7ebf2;
      --text: #0f172a;
      --text-muted: #475569;
      --accent: #2563eb;
      --radius: 16px;
      --radius-sm: 10px;
      --th-bg: #eef2fb;
      --row-alt: #f8fafc;
      --shadow-sm: 0 1px 2px rgba(15,23,42,0.04), 0 1px 3px rgba(15,23,42,0.06);
      --font-sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-sans); background: var(--bg); color: var(--text); max-width: 980px; margin: 0 auto; padding: 2rem 1.25rem; line-height: 1.5; -webkit-font-smoothing: antialiased; }
    h1 { font-size: 1.65rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 1.25rem; }
    .summary { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem 1.25rem; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.8; box-shadow: var(--shadow-sm); }
    .summary strong { color: var(--text-muted); font-weight: 500; }
    .summary span { color: var(--text); font-weight: 600; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 2rem; border: 1px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; box-shadow: var(--shadow-sm); }
    thead th { position: sticky; top: 0; background: var(--th-bg); color: var(--text-muted); font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.6rem 1rem; text-align: left; }
    td { padding: 0.5rem 1rem; border-bottom: 1px solid var(--border); vertical-align: middle; font-size: 0.9rem; }
    tr:last-child td { border-bottom: none; }
    tr:nth-child(even) td { background: var(--row-alt); }
    tbody tr { transition: background 0.15s ease; }
    tbody tr:hover td { background: var(--surface2); }
    td:first-child { font-variant-numeric: tabular-nums; color: var(--text-muted); white-space: nowrap; }
    img { max-width: 240px; max-height: 180px; border-radius: var(--radius-sm); display: block; cursor: zoom-in; border: 1px solid var(--border); transition: opacity 0.15s ease; }
    .img-link:hover img { opacity: 0.82; }
    .no-snap { color: var(--text-muted); font-style: italic; font-size: 0.85rem; }
    .no-events { color: var(--text-muted); font-style: italic; padding: 2rem 0; }
  </style>
</head>
<body>
  <h1>Motion Report</h1>
  <div class="summary">
    <strong>Date:</strong> <span>{{ night }}</span><br>
    <strong>Window:</strong> <span>{{ sunset_time }} → {{ sunrise_time }}</span><br>
    <strong>Total events:</strong> <span>{{ events|length }}</span>
  </div>

  {% if events %}
  <table>
    <thead>
      <tr><th>Time (CET)</th><th>Camera</th><th>Screenshot</th></tr>
    </thead>
    <tbody>
      {% for event in events %}
      <tr>
        <td>{{ event.timestamp.strftime("%H:%M:%S") }}</td>
        <td>{{ event.camera_name }}</td>
        <td>
          {% if event.screenshot_b64 %}
          <a class="img-link" href="#" data-caption="{{ event.timestamp.strftime('%H:%M:%S') }} · {{ event.camera_name }}" onclick="openLightbox(this);return false;">
            <img src="data:image/jpeg;base64,{{ event.screenshot_b64 }}" alt="snapshot {{ event.camera_name }}">
          </a>
          {% else %}
          <span class="no-snap">snapshot unavailable</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="no-events">No motion events detected during this session.</p>
  {% endif %}

  {% include "_lightbox.html.j2" %}
  <script>
    function reportLinks() { return Array.prototype.slice.call(document.querySelectorAll('.img-link')); }
    var lb = initLightbox({
      src: function (n) { return n.querySelector('img').src; },
      caption: function (n) { return n.getAttribute('data-caption'); },
      prev: function (n) { var l = reportLinks(), i = l.indexOf(n); return i > 0 ? l[i - 1] : null; },
      next: function (n) { var l = reportLinks(), i = l.indexOf(n); return i < l.length - 1 ? l[i + 1] : null; }
    });
    function openLightbox(link) { lb.open(link); }
  </script>
</body>
</html>
